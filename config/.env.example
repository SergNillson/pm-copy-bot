# Пример файла с переменными окружения
# Скопируйте этот файл как .env и заполните своими значениями

# API ключи Polymarket (для будущего использования в live режиме)
# POLYMARKET_API_KEY=your_api_key_here
# POLYMARKET_SECRET=your_secret_here

# Приватный ключ кошелька (для будущего использования в live режиме)
# WALLET_PRIVATE_KEY=your_private_key_here

# Примечание: В режиме paper trading эти ключи не требуются